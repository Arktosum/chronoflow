<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+: back up the SQLite databases (river.db) to Google cloud
     backup and include them in device-to-device transfers. -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="."/>
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="."/>
    </device-transfer>
</data-extraction-rules>
